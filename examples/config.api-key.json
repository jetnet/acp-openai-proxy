{
  "server": {
    "host": "127.0.0.1",
    "port": 11435,
    "api_key": "local-proxy-token",
    "request_timeout_seconds": 3600,
    "routing_strategy": "sticky_failover",
    "max_retries": 1,
    "max_attempts_per_request": 0,
    "failure_cooldown_seconds": 60,
    "retry_backoff_seconds": 0,
    "retry_on_any_acp_error": false,
    "affinity_prefix_chars": 4096
  },
  "agents": [
    {
      "_comment": "GEMINI CLI — API key. model_selection: NOT supported (session/new returns no configOptions). One agent block per model. GEMINI_API_KEY from https://aistudio.google.com/apikey.",
      "name": "gemini",
      "instance_id": "gemini-a",
      "command": "npx",
      "args": ["-y", "@google/gemini-cli@latest", "--model", "auto", "--experimental-acp"],
      "cwd": ".",
      "models": ["gemini"],
      "env": {
        "GEMINI_API_KEY": "{var:GEMINI_API_KEY_A}",
        "GEMINI_CLI_HOME": "${AUTH_ROOT:-$HOME/.acp-auth}/gemini-a"
      },
      "permission": "deny"
    },
    {
      "name": "gemini",
      "instance_id": "gemini-b",
      "command": "npx",
      "args": ["-y", "@google/gemini-cli@latest", "--model", "auto", "--experimental-acp"],
      "cwd": ".",
      "models": ["gemini"],
      "env": {
        "GEMINI_API_KEY": "{var:GEMINI_API_KEY_B}",
        "GEMINI_CLI_HOME": "${AUTH_ROOT:-$HOME/.acp-auth}/gemini-b"
      },
      "permission": "deny"
    },

    {
      "_comment": "CLAUDE AGENT ACP — API key. model_selection: SUPPORTED (confirmed via session/new). configId=model, ACP values: default=Sonnet 4.6, opus=Opus 4.7, haiku=Haiku 4.5, opus[1m]=Opus 4.7 1M ctx. ANTHROPIC_API_KEY from https://console.anthropic.com/settings/keys.",
      "name": "claude",
      "instance_id": "claude-a",
      "command": "npx",
      "args": ["-y", "@agentclientprotocol/claude-agent-acp@latest"],
      "cwd": ".",
      "models": ["claude-sonnet", "claude-opus", "claude-haiku"],
      "model_selection": {
        "type": "session_config",
        "config_id": "model",
        "values": {
          "claude-sonnet": "default",
          "claude-opus":   "opus",
          "claude-haiku":  "haiku"
        }
      },
      "env": {
        "ANTHROPIC_API_KEY": "{var:ANTHROPIC_API_KEY}",
        "HOME": "${AUTH_ROOT:-$HOME/.acp-auth}/claude-a"
      },
      "permission": "deny"
    },

    {
      "_comment": "GITHUB COPILOT — PAT auth. model_selection: SUPPORTED (confirmed via session/new). configId=model, full model list live from copilot session/new. GH_TOKEN must have 'Copilot Requests' (read) permission. Create at https://github.com/settings/tokens.",
      "name": "copilot",
      "instance_id": "copilot-a",
      "command": "npx",
      "args": ["-y", "@github/copilot@latest", "--acp", "--stdio", "--model", "gpt-5.2"],
      "cwd": ".",
      "models": [
        "copilot-auto",
        "copilot-claude-sonnet-4.6",
        "copilot-claude-sonnet-4.5",
        "copilot-claude-haiku-4.5",
        "copilot-claude-opus-4.7",
        "copilot-claude-opus-4.6",
        "copilot-claude-opus-4.5",
        "copilot-gpt-5.4",
        "copilot-gpt-5.3-codex",
        "copilot-gpt-5.2-codex",
        "copilot-gpt-5.2",
        "copilot-gpt-5-mini",
        "copilot-gpt-4.1"
      ],
      "model_selection": {
        "type": "session_config",
        "config_id": "model",
        "values": {
          "copilot-auto":              "auto",
          "copilot-claude-sonnet-4.6": "claude-sonnet-4.6",
          "copilot-claude-sonnet-4.5": "claude-sonnet-4.5",
          "copilot-claude-haiku-4.5":  "claude-haiku-4.5",
          "copilot-claude-opus-4.7":   "claude-opus-4.7",
          "copilot-claude-opus-4.6":   "claude-opus-4.6",
          "copilot-claude-opus-4.5":   "claude-opus-4.5",
          "copilot-gpt-5.4":           "gpt-5.4",
          "copilot-gpt-5.3-codex":     "gpt-5.3-codex",
          "copilot-gpt-5.2-codex":     "gpt-5.2-codex",
          "copilot-gpt-5.2":           "gpt-5.2",
          "copilot-gpt-5-mini":        "gpt-5-mini",
          "copilot-gpt-4.1":           "gpt-4.1"
        }
      },
      "env": {
        "GH_TOKEN": "{var:GH_TOKEN}",
        "COPILOT_HOME": "${AUTH_ROOT:-$HOME/.acp-auth}/copilot-a"
      },
      "permission": "deny"
    },

    {
      "_comment": "CODEX ACP (Zed) — API key. model_selection: SUPPORTED (configId=model, values: gpt-5.5, gpt-5.4, gpt-5.4-mini, gpt-5.3-codex, gpt-5.2). NO_BROWSER=1 suppresses ChatGPT OAuth prompt so only API key auth is offered. OPENAI_API_KEY from https://platform.openai.com/api-keys.",
      "name": "codex",
      "instance_id": "codex-a",
      "command": "npx",
      "args": ["-y", "@zed-industries/codex-acp@latest"],
      "cwd": ".",
      "models": ["codex-gpt-5.5", "codex-gpt-5.4", "codex-gpt-5.4-mini", "codex-gpt-5.3-codex", "codex-gpt-5.2"],
      "model_selection": {
        "type": "session_config",
        "config_id": "model",
        "values": {
          "codex-gpt-5.5":       "gpt-5.5",
          "codex-gpt-5.4":       "gpt-5.4",
          "codex-gpt-5.4-mini":  "gpt-5.4-mini",
          "codex-gpt-5.3-codex": "gpt-5.3-codex",
          "codex-gpt-5.2":       "gpt-5.2"
        }
      },
      "env": {
        "OPENAI_API_KEY": "{var:OPENAI_API_KEY}",
        "NO_BROWSER": "1",
        "HOME": "${AUTH_ROOT:-$HOME/.acp-auth}/codex-a"
      },
      "permission": "deny"
    },

    {
      "_comment": "OPENCODE — API key. model_selection: SUPPORTED via session_config (auto-detected from session/new). opencode acp runs as a stdio subprocess; the launched 'acp' subcommand speaks JSON-RPC over stdio without a --model flag. The proxy switches model per request via session/set_config_option. required=false lets the proxy fall back silently if a particular session does not expose the option. ANTHROPIC_API_KEY from https://console.anthropic.com/settings/keys.",
      "name": "opencode",
      "instance_id": "opencode-a",
      "command": "npx",
      "args": ["-y", "opencode-ai@latest", "acp"],
      "cwd": ".",
      "models": [
        "opencode/claude-sonnet-4-6",
        "opencode/claude-haiku-4-5",
        "anthropic/claude-sonnet-4-6"
      ],
      "model_selection": {
        "type": "session_config",
        "values": {
          "opencode/claude-sonnet-4-6": "opencode/claude-sonnet-4-6",
          "opencode/claude-haiku-4-5":  "opencode/claude-haiku-4-5",
          "anthropic/claude-sonnet-4-6": "anthropic/claude-sonnet-4-6"
        },
        "required": false
      },
      "env": {
        "ANTHROPIC_API_KEY": "{var:ANTHROPIC_API_KEY}",
        "XDG_DATA_HOME": "${AUTH_ROOT:-$HOME/.acp-auth}/opencode-a/.local/share",
        "XDG_CONFIG_HOME": "${AUTH_ROOT:-$HOME/.acp-auth}/opencode-a/.config"
      },
      "permission": "deny"
    }
  ]
}
