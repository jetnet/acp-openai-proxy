{
    "server": {
        "host": "127.0.0.1",
        "port": 11435,
        "api_key": "123",
        "logging": {
            "level": "info",
            "format": "text"
        },
        "routing_strategy": "sticky_failover",
        "max_retries": 3,
        "failure_cooldown_seconds": 60
    },
    "agents": [
        {
            "_comment": "Codex with oauth",
            "name": "codex",
            "instance_id": "codex-a",
            "command": "npx",
            "args": ["-y", "@zed-industries/codex-acp@latest"],
            "cwd": ".",
            "models": ["gpt-5-mini"],
            "model_selection": {
                "type": "session_config",
                "values": {
                    "codex-gpt-5.5": "gpt-5.5/xhigh",
                    "codex-gpt-5.4": "gpt-5.4/xhigh",
                    "codex-gpt-5": "gpt-5.4-mini/xhigh",
                    "codex-gpt-5.3-codex": "gpt-5.3-codex/xhigh",
                    "codex-gpt-5.2": "gpt-5.2/xhigh"
                },
                "required": false
            },
            "env": {},
            "permission": "deny",
            "assume_authed": true
        },
        {
            "_comment": "OPENCODE + Gitlab Duo oauth",
            "name": "opencode",
            "instance_id": "opencode-a",
            "command": "npx",
            "args": ["-y", "opencode-ai@latest", "acp"],
            "cwd": ".",
            "models": ["big-pickle", "gpt-5-mini"],
            "model_selection": {
                "type": "session_config",
                "values": {
                    "big-pickle": "opencode/big-pickle",
                    "opencode/deepseek-v4-flash-free": "opencode/deepseek-v4-flash-free",
                    "opencode/minimax-m2.5-free": "opencode/minimax-m2.5-free",
                    "opencode/nemotron-3-super-free": "opencode/nemotron-3-super-free",
                    "opencode/ring-2.6-1t-free": "opencode/ring-2.6-1t-free",
                    "gitlab/duo-chat-gpt-5-1": "gitlab/duo-chat-gpt-5-1",
                    "gitlab/duo-chat-gpt-5-2": "gitlab/duo-chat-gpt-5-2",
                    "gitlab/duo-chat-gpt-5-2-codex": "gitlab/duo-chat-gpt-5-2-codex",
                    "gitlab/duo-chat-gpt-5-3-codex": "gitlab/duo-chat-gpt-5-3-codex",
                    "gitlab/duo-chat-gpt-5-4": "gitlab/duo-chat-gpt-5-4",
                    "gitlab/duo-chat-gpt-5-4-mini": "gitlab/duo-chat-gpt-5-4-mini",
                    "gitlab/duo-chat-gpt-5-4-nano": "gitlab/duo-chat-gpt-5-4-nano",
                    "gitlab/duo-chat-gpt-5-codex": "gitlab/duo-chat-gpt-5-codex",
                    "gpt-5-mini": "gitlab/duo-chat-gpt-5-mini",
                    "gitlab/duo-chat-haiku-4-5": "gitlab/duo-chat-haiku-4-5",
                    "gitlab/duo-chat-opus-4-5": "gitlab/duo-chat-opus-4-5",
                    "gitlab/duo-chat-opus-4-6": "gitlab/duo-chat-opus-4-6",
                    "gitlab/duo-chat-opus-4-7": "gitlab/duo-chat-opus-4-7",
                    "gitlab/duo-chat-sonnet-4-5": "gitlab/duo-chat-sonnet-4-5",
                    "gitlab/duo-chat-sonnet-4-6": "gitlab/duo-chat-sonnet-4-6"
                },
                "required": false
            },
            "env": {},
            "permission": "deny",
            "assume_authed": true
        },
        {
            "name": "gemini",
            "instance_id": "gemini-jn",
            "command": "npx",
            "args": [
                "-y",
                "@google/gemini-cli@latest",
                "--model",
                "auto",
                "--acp",
                "--skip-trust"
            ],
            "models": ["gemini-pro", "gemini-flash", "gemini-flash-lite"],
            "model_selection": {
                "type": "gemini",
                "values": {
                    "gemini-pro": "gemini-3.1-pro-preview",
                    "gemini-flash": "gemini-3-flash-preview",
                    "gemini-flash-lite": "gemini-3.1-flash-lite-preview"
                },
                "required": true
            },
            "env": { "GEMINI_CLI_HOME": "/home/user/.gemini.userz" },
            "permission": "deny",
            "assume_authed": true
        },
        {
            "name": "gemini",
            "instance_id": "gemini-dv",
            "command": "npx",
            "args": [
                "-y",
                "@google/gemini-cli@latest",
                "--model",
                "auto",
                "--acp",
                "--skip-trust"
            ],
            "models": ["gemini-pro", "gemini-flash", "gemini-flash-lite"],
            "model_selection": {
                "type": "gemini",
                "values": {
                    "gemini-pro": "gemini-3.1-pro-preview",
                    "gemini-flash": "gemini-3-flash-preview",
                    "gemini-flash-lite": "gemini-3.1-flash-lite-preview"
                },
                "required": true
            },
            "env": {
                "GEMINI_CLI_HOME": "/home/user"
            },
            "permission": "deny",
            "assume_authed": true
        },
        {
            "name": "claude",
            "instance_id": "claude-us",
            "command": "npx",
            "args": ["-y", "@agentclientprotocol/claude-agent-acp"],
            "models": ["claude-haiku"],
            "model_selection": {
                "type": "session_config",
                "values": {
                    "claude-sonnet": "default",
                    "claude-opus": "opus",
                    "claude-opus[1m]": "opus[1m]",
                    "claude-haiku": "haiku"
                }
            },
            "permission": "deny",
            "assume_authed": true
        },
        {
            "name": "github",
            "instance_id": "github-us",
            "command": "npx",
            "args": [
                "--yes",
                "--package",
                "@github/copilot@latest",
                "copilot",
                "--acp",
                "--stdio",
                "--model",
                "copilot-auto",
                "--effort",
                "high"
            ],
            "models": ["gpt-5-mini"],
            "model_selection": {
                "type": "session_config",

                "values": {
                    "copilot-auto": "auto",
                    "copilot-claude-sonnet-4.6": "claude-sonnet-4.6",
                    "copilot-claude-sonnet-4.5": "claude-sonnet-4.5",
                    "copilot-claude-haiku-4.5": "claude-haiku-4.5",
                    "copilot-claude-opus-4.7": "claude-opus-4.7",
                    "copilot-claude-opus-4.6": "claude-opus-4.6",
                    "copilot-claude-opus-4.5": "claude-opus-4.5",
                    "copilot-gpt-5.4": "gpt-5.4",
                    "copilot-gpt-5.3-codex": "gpt-5.3-codex",
                    "copilot-gpt-5.2-codex": "gpt-5.2-codex",
                    "copilot-gpt-5.2": "gpt-5.2",
                    "gpt-5-mini": "gpt-5-mini",
                    "copilot-gpt-4.1": "gpt-4.1"
                }
            },
            "permission": "deny",
            "assume_authed": true
        }
    ]
}
